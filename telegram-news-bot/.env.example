# Copy this file to .env and fill in your values
# Keep .env private — never commit it

# REQUIRED
TELEGRAM_BOT_TOKEN=""          # From @BotFather on Telegram
TELEGRAM_CHANNEL_ID=""         # e.g. @yourchannel  OR  -100xxxxxxxxxx (numeric)

# OPTIONAL — adds more news sources (free tier available)
GNEWS_API_KEY=""               # https://gnews.io  (100 req/day free)
NEWSAPI_KEY=""                 # https://newsapi.org (100 req/day free)

# OPTIONAL — from existing .env.example in savage folder
X_BEARER_TOKEN=""              # X/Twitter bearer token for social signal
