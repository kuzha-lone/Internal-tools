{
  "video_provider": "heygen",
  "voice_provider": "heygen",
  "captions_enabled": false,
  "layout": {
    "format": "9:16",
    "width": 1080,
    "height": 1920,
    "top_half_source": "hyperframes",
    "bottom_half_source": "heygen",
    "top_half_height": 960,
    "bottom_half_height": 960,
    "top_half_viewport": {
      "width": 1080,
      "height": 960
    },
    "hyperframes_safe_zone": {
      "width": 960,
      "height": 890,
      "anchor": "centered-in-top-half-viewport"
    },
    "bottom_half_avatar_fit": "proportional-zoom-to-fit-crop-only",
    "hyperframes_frame": "1:1"
  },
  "hyperframes": {
    "provider": "hyperframes",
    "output_frame": "1:1",
    "fit": "cover",
    "position": "top-half",
    "prompt_source": "derived-from-approved-script"
  },
  "avatar_rotation": {
    "enabled": true,
    "strategy": "daily-three-run-cycle",
    "default_run_slot": 1,
    "avatar_look_ids": [
      "(insert HeyGen avatar look ID 1 here)",
      "(insert HeyGen avatar look ID 2 here)",
      "(insert HeyGen avatar look ID 3 here)"
    ]
  },
  "assembly": {
    "tool": "ffmpeg",
    "ffmpeg_path": "ffmpeg",
    "ffprobe_path": "ffprobe",
    "stack_mode": "vertical-halves",
    "preserve_raw_assets": true
  },
  "title_behavior": {
    "mode": "auto",
    "tone": "viral_edgy_relatable",
    "placement": "bottom_half_lower_third_under_face",
    "font_path": "Helvetica75 Bold/Helvetica75 Bold.ttf",
    "font_size": 48,
    "max_line_chars": 22,
    "outer_margin_px": 70,
    "horizontal_padding_px": 72,
    "vertical_padding_px": 24,
    "line_spacing_px": 18,
    "text_color": "#ffffff",
    "background_color": "#000000",
    "background_shape": "square_corners_rectangle",
    "never_truncate_manual_titles": true,
    "must_fit_inside_frame": true
  },
  "render": {
    "width": 1080,
    "height": 1920,
    "background": "#101010",
    "duration_seconds_min": 15,
    "duration_seconds_max": 30
  },
  "ids": {
    "heygen_avatar_id": "(insert HeyGen avatar ID here)",
    "heygen_talking_photo_id": "(insert HeyGen talking photo ID here)",
    "heygen_avatar_look_id": "(insert HeyGen avatar look ID here)",
    "heygen_voice_id": "(insert HeyGen voice ID here)",
    "elevenlabs_voice_id": "(insert ElevenLabs voice ID here if using ElevenLabs)"
  },
  "reference_image_path": "skills/trending-news-character-skill/subskills/talking-video-skill/assets/reference-image.jpg"
}
