# ── Shared ────────────────────────────────────────────────
DATABASE_URL=postgresql://tradebrain:tradebrain@localhost:5432/tradebrain
REDIS_URL=redis://localhost:6379
ANTHROPIC_API_KEY=
# or GOOGLE_AI_API_KEY=

# ── News engine ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=                # e.g. @yourchannel or -100xxxxxxxx
TELEGRAM_API_ID=                    # only needed for Telethon (private channel reading)
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
NEWS_API_KEY=                       # NewsAPI.org free tier, optional
WEBSITE_API_URL=https://yoursite.com/api/news
WEBSITE_API_KEY=

# ── Trading engine — MT5 (demo first, always) ───────────────
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_ACCOUNT_TYPE=demo               # demo | live -- never default this to live

# ── Trading engine — cTrader (demo first, always) ────────────
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
CTRADER_ACCOUNT_ID=
CTRADER_ACCOUNT_TYPE=demo

# ── Social distribution ──────────────────────────────────────
TWITTER_BEARER_TOKEN=               # only when you're ready to add a second platform
